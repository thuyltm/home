    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Blockchain",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${fileDirname}",
            "args": ["createwallet"]
        },

        {
            "name": "Debug Stream",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${fileDirname}",
            "console": "integratedTerminal",
            "args": [
                "playbin",
                "uri=https://gstreamer.freedesktop.org/data/media/sintel_tr",
                "!",
                "fakesink",
            ]
        }
    ]
}